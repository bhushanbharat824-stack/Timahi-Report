rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: reports
    // Document ID: auto-generated or manual ID
    // Fields:
    //   - id: string (required)
    //   - sectionName: string (required)
    //   - year: string (required)
    //   - quarter: string (required)
    //   - status: string (required, enum: DRAFT, PENDING_SAO, APPROVED, REJECTED)
    //   - submittedBy: string
    //   - timestamp: string (ISO date)
    //   - acknowledgementId: string
    //   - region: string
    //   - officeInfo: map
    //   - correspondence: map
    //   - section33: map
    //   - rule5: map
    //   - noting: map
    //   - workshops: map
    //   - meetings: map
    //   - achievements: string
    //   - saoRemarks: string
    //   - part2: map
    //   - authorUid: string (required for ownership)
    //
    // Collection: sections
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //
    // Collection: users
    // Document ID: auth.uid
    // Fields:
    //   - role: string (required, enum: MASTER, SAO, SECTION)
    //   - sectionName: string (optional)
    //   - email: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'MASTER' ||
          (request.auth.token.email == "bhushanbharat824@gmail.com" && request.auth.token.email_verified == true));
    }

    function isSAO() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SAO';
    }

    function isSectionUser(sectionName) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sectionName == sectionName;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidReport(data) {
      return hasRequiredFields(['id', 'sectionName', 'year', 'quarter', 'status', 'authorUid']) &&
             data.id is string &&
             data.sectionName is string &&
             data.year is string &&
             data.quarter is string &&
             data.status in ['DRAFT', 'PENDING_SAO', 'APPROVED', 'REJECTED'] &&
             data.authorUid is string &&
             data.authorUid == request.auth.uid;
    }

    function isValidSection(data) {
      return hasRequiredFields(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidUser(data) {
      return hasRequiredFields(['role']) &&
             data.role in ['MASTER', 'SAO', 'SECTION'] &&
             (!('sectionName' in data) || data.sectionName is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Only admins can create/update roles, or a user can create their own initial 'SECTION' role
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isAdmin() || (isOwner(userId) && request.resource.data.role == 'SECTION'));
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }

    match /reports/{reportId} {
      allow read: if isAuthenticated() && (isAdmin() || isSAO() || resource.data.authorUid == request.auth.uid);
      
      allow create: if isAuthenticated() && isValidReport(request.resource.data);
      
      allow update: if isAuthenticated() && isValidReport(request.resource.data) && 
                    (
                      // Owner can update if it's a draft or rejected
                      (resource.data.authorUid == request.auth.uid && (resource.data.status == 'DRAFT' || resource.data.status == 'REJECTED')) ||
                      // SAO/Admin can update status and remarks
                      isAdmin() || isSAO()
                    );
      
      allow delete: if isAuthenticated() && (isAdmin() || (resource.data.authorUid == request.auth.uid && resource.data.status == 'DRAFT'));
    }

    match /sections/{sectionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
